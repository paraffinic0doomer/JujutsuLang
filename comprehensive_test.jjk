// Test all keywords
CursedEnergy var_int;
ReversedFlow var_float;
DomainPower var_double;
SoulShard var_char;
NullVoid func_void();

// Test operators
CursedEnergy Add ReversedFlow;
CursedEnergy Drain ReversedFlow;
CursedEnergy Amplify ReversedFlow;
CursedEnergy Divide ReversedFlow;
CursedEnergy ShardMod ReversedFlow;
CursedEnergy Match ReversedFlow;
CursedEnergy Clash ReversedFlow;
CursedEnergy Below ReversedFlow;
CursedEnergy Above ReversedFlow;
CursedEnergy BelowEq ReversedFlow;
CursedEnergy AboveEq ReversedFlow;
CursedEnergy Chain ReversedFlow;
CursedEnergy Link ReversedFlow;
CursedEnergy Neg ReversedFlow;
CursedEnergy Boost ReversedFlow;
CursedEnergy Bind ReversedFlow;

// Test control flow keywords
TriggerCondition (x Match 5) {
    CounterMove {
        DomainShatter;
    }
}

ShikigamiSummon (x) {
    ShikigamiForm 1:
        FlowShift;
    ShikigamiForm 2:
        SukunaRelease 0;
}

BindingLoop (CursedEnergy i Bind 0; i Below 10; i Boost) {
    CursedCycle (GuaranteedHit) {
        x Bind 1;
    }
}

/* Multi-line comment testing */
DomainScale(CursedEnergy);

// Test literals
CursedEnergy int_lit Bind 42;
ReversedFlow float_lit Bind 3.14;
SoulShard char_lit Bind 'a';
// String test would go here

// Identifiers
my_variable Bind 10;
_private_var Bind 20;

// Punctuation
myFunc(a, b) -> c;
array[10];
object.field;
a : b;
address &ptr;
