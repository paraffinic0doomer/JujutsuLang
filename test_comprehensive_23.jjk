// JujutsuLang Phase 2 & 3 Comprehensive Test
// Tests expressions, declarations, assignments, and control flow

CursedEnergy num1 Bind 100;
CursedEnergy num2 Bind 50;
CursedEnergy total Bind num1 Add num2;

// Test all arithmetic operations
CursedEnergy add_test Bind 10 Add 5;
CursedEnergy sub_test Bind 10 Drain 3;
CursedEnergy mul_test Bind 7 Amplify 8;
CursedEnergy div_test Bind 20 Divide 4;
CursedEnergy mod_test Bind 17 ShardMod 5;

// Test comparison operators
CursedEnergy cmp_gt Bind 15 Above 10;
CursedEnergy cmp_lt Bind 5 Below 10;
CursedEnergy cmp_gte Bind 10 AboveEq 10;
CursedEnergy cmp_lte Bind 9 BelowEq 10;
CursedEnergy cmp_eq Bind 7 Match 7;
CursedEnergy cmp_neq Bind 5 Clash 3;

// Test logical operators
CursedEnergy logic_and Bind 1 Chain 1;
CursedEnergy logic_or Bind 0 Link 1;
CursedEnergy logic_not Bind Neg 0;

// Test operator precedence
CursedEnergy prec1 Bind 2 Add 3 Amplify 4;
CursedEnergy prec2 Bind 10 Divide 2 Add 3;
CursedEnergy prec3 Bind 5 Add 5 Drain 2 Amplify 3;

// Test unary negation
CursedEnergy neg_test Bind Neg 42;
CursedEnergy pos_test Bind Neg (Neg 50);

// Test parenthesized expressions
CursedEnergy paren_test Bind (2 Add 3) Amplify 4;

// Test control flow - if statement
TriggerCondition (total Above 100) {
    CursedEnergy control_result Bind 1;
} CounterMove {
    CursedEnergy control_result Bind 0;
};
