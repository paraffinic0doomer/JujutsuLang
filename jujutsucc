#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
INPUT_FILE="${1:-}"

if [[ -z "$INPUT_FILE" ]]; then
  echo "Usage: ./jujutsucc <program.jjk>"
  exit 1
fi

if [[ ! -f "$INPUT_FILE" ]]; then
  if [[ -f "$ROOT_DIR/$INPUT_FILE" ]]; then
    INPUT_FILE="$ROOT_DIR/$INPUT_FILE"
  else
    echo "Error: file not found: $INPUT_FILE"
    exit 1
  fi
fi

INPUT_FILE="$(realpath "$INPUT_FILE")"
INPUT_DIR="$(dirname "$INPUT_FILE")"
INPUT_BASE="$(basename "$INPUT_FILE")"
SOURCE_NAME="${INPUT_BASE%.*}"

TARGET_EXE="$INPUT_DIR/$SOURCE_NAME.exe"
GENERATED_C="$INPUT_DIR/$SOURCE_NAME.c"

COMPILER_EXE="$ROOT_DIR/jujutsu.exe"
GRAMMAR_SRC="$ROOT_DIR/jujutsu.y"
LEXER_SRC="$ROOT_DIR/jujutsu.l"
PARSER_CPP="$ROOT_DIR/jujutsu.tab.c"
LEXER_CPP="$ROOT_DIR/lex.yy.c"

BUILD_LOG="$(mktemp)"
BUILD_ERR="$(mktemp)"
COMP_LOG="$(mktemp)"
COMP_ERR="$(mktemp)"

cleanup() {
  rm -f "$BUILD_LOG" "$BUILD_ERR" "$COMP_LOG" "$COMP_ERR"
}
trap cleanup EXIT

build_needed=0
if [[ ! -x "$COMPILER_EXE" ]]; then
  build_needed=1
elif [[ "$GRAMMAR_SRC" -nt "$COMPILER_EXE" || "$LEXER_SRC" -nt "$COMPILER_EXE" ]]; then
  build_needed=1
fi

if [[ "$build_needed" -eq 1 ]]; then
  if ! bison -d "$GRAMMAR_SRC" >"$BUILD_LOG" 2>"$BUILD_ERR"; then
    cat "$BUILD_ERR"
    cat "$BUILD_LOG"
    exit 1
  fi

  if ! flex -o "$LEXER_CPP" "$LEXER_SRC" >>"$BUILD_LOG" 2>>"$BUILD_ERR"; then
    cat "$BUILD_ERR"
    cat "$BUILD_LOG"
    exit 1
  fi

  if ! g++ -x c++ -o "$COMPILER_EXE" "$PARSER_CPP" "$LEXER_CPP" -lfl >>"$BUILD_LOG" 2>>"$BUILD_ERR"; then
    cat "$BUILD_ERR"
    cat "$BUILD_LOG"
    exit 1
  fi
fi

if ! (
  cd "$INPUT_DIR"
  JUJUTSU_NO_INTERACTIVE_SCAN=1 "$COMPILER_EXE" "$INPUT_FILE" >"$COMP_LOG" 2>"$COMP_ERR" < /dev/null
); then
  cat "$COMP_ERR"
  cat "$COMP_LOG"
  exit 1
fi

if [[ ! -f "$INPUT_DIR/output.c" ]]; then
  echo "Error: output.c was not generated. Compilation failed."
  exit 1
fi

cp "$INPUT_DIR/output.c" "$GENERATED_C"

if ! g++ -x c++ -o "$TARGET_EXE" "$GENERATED_C" >>"$BUILD_LOG" 2>>"$BUILD_ERR"; then
  cat "$BUILD_ERR"
  cat "$BUILD_LOG"
  exit 1
fi

"$TARGET_EXE"
