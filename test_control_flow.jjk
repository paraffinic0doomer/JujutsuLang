// JujutsuLang Phase 3 - Control Flow Test Program

CursedEnergy x Bind 10;

// Test if-else with true condition
TriggerCondition (x Above 5) {
    CursedEnergy result Bind 1;
};

// Test if-else with false condition  
TriggerCondition (x Below 5) {
    CursedEnergy result Bind 0;
} CounterMove {
    CursedEnergy result Bind 99;
};

// Test comparison and logical operations
CursedEnergy a Bind 5;
CursedEnergy b Bind 3;
CursedEnergy test1 Bind a Above b;
CursedEnergy test2 Bind a Match b;
CursedEnergy test3 Bind a Chain b;
